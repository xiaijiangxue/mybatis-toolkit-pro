{
  "name": "mybatis-toolkit-pro",
  "displayName": "MyBatis Toolkit Pro",
  "description": "专业的 MyBatis 开发工具包",
  "version": "1.1.1",
  "publisher": "xiyeming",
  "license": "MIT",
  "keywords": [
    "mybatis",
    "sql",
    "xml",
    "java",
    "vscode",
    "database",
    "code-generation"
  ],
  "homepage": "https://github.com/xiyeming/mybatis-toolkit-pro#readme",
  "bugs": {
    "url": "https://github.com/xiyeming/mybatis-toolkit-pro/issues"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:xml",
    "onLanguage:java",
    "onLanguage:sql",
    "workspaceContains:**/*.xml"
  ],
  "main": "./dist/extension.js",
  "repository": "https://github.com/xiyeming/mybatis-toolkit-pro.git",
  "icon": "images/mybatis.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mybatis-explorer",
          "title": "MyBatis",
          "icon": "images/mybatis.png"
        }
      ]
    },
    "views": {
      "mybatis-explorer": [
        {
          "id": "mybatisToolkit.databaseExplorer",
          "name": "数据库浏览器",
          "icon": "images/mybatis.png"
        }
      ]
    },
    "commands": [
      {
        "command": "mybatisToolkit.goToMapper",
        "title": "跳转到 Mapper 接口"
      },
      {
        "command": "mybatisToolkit.goToXml",
        "title": "跳转到 MyBatis XML"
      },
      {
        "command": "mybatisToolkit.addConnection",
        "title": "添加连接",
        "icon": "$(add)"
      },
      {
        "command": "mybatisToolkit.editConnection",
        "title": "编辑连接",
        "icon": "$(edit)"
      },
      {
        "command": "mybatisToolkit.connect",
        "title": "连接",
        "icon": "$(plug)"
      },
      {
        "command": "mybatisToolkit.disconnect",
        "title": "断开连接",
        "icon": "$(plug)"
      },
      {
        "command": "mybatisToolkit.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "mybatisToolkit.removeConnection",
        "title": "移除",
        "icon": "$(trash)"
      },
      {
        "command": "mybatisToolkit.openTableSchema",
        "title": "打开表结构"
      },
      {
        "command": "mybatisToolkit.generateCode",
        "title": "生成代码 (Entity/Mapper/XML)"
      },
      {
        "command": "mybatisToolkit.generateXmlForMethod",
        "title": "为方法生成 XML (Generate XML for method)"
      },
      {
        "command": "mybatisToolkit.selectConnection",
        "title": "选择数据库",
        "icon": "$(database)"
      },
      {
        "command": "mybatisToolkit.newQuery",
        "title": "新建查询窗口",
        "icon": "$(file-code)"
      },
      {
        "command": "mybatisToolkit.runSelectedSql",
        "title": "执行选中 SQL",
        "icon": "$(play)"
      },
      {
        "command": "mybatisToolkit.runAllSql",
        "title": "执行全部 SQL",
        "icon": "$(debug-start)"
      },
      {
        "command": "mybatisToolkit.showFullStructure",
        "title": "展示全部结构 (表与列)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mybatisToolkit.addConnection",
          "when": "view == mybatisToolkit.databaseExplorer",
          "group": "navigation"
        },
        {
          "command": "mybatisToolkit.newQuery",
          "when": "view == mybatisToolkit.databaseExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "mybatisToolkit.connect",
          "when": "view == mybatisToolkit.databaseExplorer && viewItem == connection && !mybatisToolkit.connected",
          "group": "inline"
        },
        {
          "command": "mybatisToolkit.disconnect",
          "when": "view == mybatisToolkit.databaseExplorer && viewItem == connection && mybatisToolkit.connected",
          "group": "inline"
        },
        {
          "command": "mybatisToolkit.editConnection",
          "when": "view == mybatisToolkit.databaseExplorer && viewItem == connection",
          "group": "inline"
        },
        {
          "command": "mybatisToolkit.generateCode",
          "when": "view == mybatisToolkit.databaseExplorer && viewItem == table",
          "group": "1_modification"
        },
        {
          "command": "mybatisToolkit.removeConnection",
          "when": "view == mybatisToolkit.databaseExplorer && viewItem == connection",
          "group": "1_modification"
        },
        {
          "command": "mybatisToolkit.selectConnection",
          "when": "view == mybatisToolkit.databaseExplorer && viewItem == connection",
          "group": "inline"
        },
        {
          "command": "mybatisToolkit.newQuery",
          "when": "view == mybatisToolkit.databaseExplorer && viewItem == connection",
          "group": "inline"
        }
      ],
      "editor/title/run": [
        {
          "command": "mybatisToolkit.selectConnection",
          "when": "editorLangId == sql",
          "group": "navigation"
        },
        {
          "command": "mybatisToolkit.runSelectedSql",
          "when": "editorLangId == sql && mybatisToolkit.connected",
          "group": "navigation"
        },
        {
          "command": "mybatisToolkit.runAllSql",
          "when": "editorLangId == sql && mybatisToolkit.connected",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mybatisToolkit.runSelectedSql",
        "key": "ctrl+shift+,",
        "mac": "cmd+shift+,",
        "when": "editorLangId == sql"
      },
      {
        "command": "mybatisToolkit.runAllSql",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "editorLangId == sql"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "MyBatis Toolkit Pro",
      "description": "以下所有配置项均可在「设置」界面中修改：打开设置 (Ctrl+,) 搜索 MyBatis 或 mybatisToolkit 即可。",
      "order": [
        "mybatisToolkit.defaultDatabaseType",
        "mybatisToolkit.connections",
        "mybatisToolkit.database.host",
        "mybatisToolkit.database.port",
        "mybatisToolkit.database.user",
        "mybatisToolkit.database.password",
        "mybatisToolkit.database.database",
        "mybatisToolkit.database.connectionLimit",
        "mybatisToolkit.validation.enable",
        "mybatisToolkit.navigation.exclude",
        "mybatisToolkit.performance.indexParseConcurrency",
        "mybatisToolkit.performance.indexDebounceMs",
        "mybatisToolkit.performance.validationDebounceMs",
        "mybatisToolkit.queryResult.datetimeFormat",
        "mybatisToolkit.queryResult.dateFormat",
        "mybatisToolkit.queryResult.timeFormat",
        "mybatisToolkit.codeGen.mybatisPlus.fillFields",
        "mybatisToolkit.codeGen.mybatisPlus.logicDeleteField",
        "mybatisToolkit.codeGen.mybatisPlus.idType",
        "mybatisToolkit.codeGen.entityDirName",
        "mybatisToolkit.codeGen.mapperDirName",
        "mybatisToolkit.codeGen.xmlDirName",
        "mybatisToolkit.codeGen.serviceDirName",
        "mybatisToolkit.formatting.indentSize",
        "mybatisToolkit.highlights.tableNameColor",
        "mybatisToolkit.highlights.keywordColor",
        "mybatisToolkit.highlights.functionColor",
        "mybatisToolkit.highlights.paramColor"
      ],
      "properties": {
        "mybatisToolkit.defaultDatabaseType": {
          "type": "string",
          "enum": [
            "MySQL",
            "PostgreSQL",
            "Oracle",
            "SQL Server",
            "SQLite",
            "DB2",
            "H2",
            "MariaDB"
          ],
          "default": "MySQL",
          "description": "默认数据库类型",
          "markdownDescription": "用于 **SQL 高亮/格式化** 的默认方言。若已连接数据库，将优先使用当前连接类型。"
        },
        "mybatisToolkit.connections": {
          "type": "array",
          "default": [],
          "description": "数据库连接列表",
          "markdownDescription": "在 **MyBatis 侧边栏** 中管理的多数据源。每项包含：名称、类型、主机、端口、用户、密码、数据库。密码由扩展安全存储。",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "连接唯一 ID" },
              "name": { "type": "string", "description": "显示名称" },
              "type": {
                "type": "string",
                "enum": ["MySQL", "PostgreSQL", "Oracle", "SQL Server", "SQLite", "DB2", "H2", "MariaDB"],
                "default": "MySQL",
                "description": "数据库类型"
              },
              "host": { "type": "string", "description": "主机地址" },
              "port": { "type": "number", "description": "端口" },
              "user": { "type": "string", "description": "用户名" },
              "password": { "type": "string", "description": "密码" },
              "database": { "type": "string", "description": "数据库/Schema 名" }
            }
          }
        },
        "mybatisToolkit.database.host": {
          "type": "string",
          "default": "localhost",
          "description": "默认连接：主机",
          "markdownDescription": "未配置多连接时使用的 **单连接** 主机。建议在侧栏「添加连接」后使用 `connections`。"
        },
        "mybatisToolkit.database.port": {
          "type": "number",
          "default": 3306,
          "description": "默认连接：端口",
          "markdownDescription": "数据库端口，如 MySQL 3306、PostgreSQL 5432。",
          "minimum": 1,
          "maximum": 65535
        },
        "mybatisToolkit.database.user": {
          "type": "string",
          "default": "root",
          "description": "默认连接：用户名",
          "markdownDescription": "数据库登录用户名。"
        },
        "mybatisToolkit.database.password": {
          "type": "string",
          "default": "",
          "description": "默认连接：密码",
          "markdownDescription": "数据库登录密码。多连接时建议在侧栏添加连接，密码由扩展安全存储。"
        },
        "mybatisToolkit.database.database": {
          "type": "string",
          "default": "",
          "description": "默认连接：数据库名",
          "markdownDescription": "要连接的数据库 / Schema 名称。"
        },
        "mybatisToolkit.database.connectionLimit": {
          "type": "number",
          "default": 10,
          "description": "连接池大小",
          "markdownDescription": "数据库连接池最大连接数。",
          "minimum": 1,
          "maximum": 100
        },
        "mybatisToolkit.validation.enable": {
          "type": "boolean",
          "default": true,
          "description": "启用 SQL 与映射验证",
          "markdownDescription": "在 XML Mapper 中实时校验：表/列是否存在、resultMap/resultType 与 Java 属性是否一致。"
        },
        "mybatisToolkit.navigation.exclude": {
          "type": "array",
          "default": ["target", "build", "bin", "out", "dist", "node_modules", ".git"],
          "description": "索引排除目录",
          "markdownDescription": "扫描 Java/XML 时跳过的文件夹名（不含路径），用于减少无关代码参与 Mapper 索引与跳转。",
          "items": { "type": "string" }
        },
        "mybatisToolkit.performance.indexParseConcurrency": {
          "type": "number",
          "default": 20,
          "description": "索引并发数",
          "markdownDescription": "同时解析的 Java/XML 文件数量。大仓库可适当调低以降低 CPU 峰值；高性能机器可调高以加快索引。",
          "minimum": 5,
          "maximum": 100
        },
        "mybatisToolkit.performance.indexDebounceMs": {
          "type": "number",
          "default": 300,
          "description": "文件变更防抖（毫秒）",
          "markdownDescription": "文件保存后延迟多少毫秒再触发索引更新与 CodeLens 刷新。可减少频繁保存时的重复计算。",
          "minimum": 50,
          "maximum": 2000
        },
        "mybatisToolkit.performance.validationDebounceMs": {
          "type": "number",
          "default": 400,
          "description": "诊断防抖（毫秒）",
          "markdownDescription": "编辑 XML 后延迟多少毫秒再运行 SQL 诊断。",
          "minimum": 100,
          "maximum": 2000
        },
        "mybatisToolkit.queryResult.datetimeFormat": {
          "type": "string",
          "default": "%Y-%m-%d %H:%i:%s",
          "description": "查询结果：日期时间格式",
          "markdownDescription": "返回结果中日期时间列的显示格式。占位符：`%Y` 年 `%m` 月 `%d` 日 `%H` 时 `%i` 分 `%s` 秒。默认 `%Y-%m-%d %H:%i:%s`。"
        },
        "mybatisToolkit.queryResult.dateFormat": {
          "type": "string",
          "default": "%Y-%m-%d",
          "description": "查询结果：仅日期格式",
          "markdownDescription": "仅日期（无时间）时的显示格式。默认 `%Y-%m-%d`。"
        },
        "mybatisToolkit.queryResult.timeFormat": {
          "type": "string",
          "default": "%H:%i:%s",
          "description": "查询结果：仅时间格式",
          "markdownDescription": "仅时间（无日期）时的显示格式。默认 `%H:%i:%s`。"
        },
        "mybatisToolkit.codeGen.mybatisPlus.fillFields": {
          "type": "array",
          "default": [],
          "description": "MyBatis-Plus 自动填充字段（在设置 UI 中可添加/编辑，生成 Entity 时生效）",
          "markdownDescription": "选择 **MyBatis-Plus** 风格生成时，为指定列添加 `@TableField(value = \"列名\", fill = FieldFill.INSERT)` 或 `INSERT_UPDATE`。在设置中点击「添加项」可新增一行，每项填写 **column**（数据库列名，如 create_time）和 **fill**（INSERT 仅插入时填充，INSERT_UPDATE 插入与更新时填充）。",
          "items": {
            "type": "object",
            "required": ["column", "fill"],
            "properties": {
              "column": {
                "type": "string",
                "description": "数据库列名",
                "default": "",
                "markdownDescription": "如 `create_time`、`update_time`"
              },
              "fill": {
                "type": "string",
                "enum": ["INSERT", "INSERT_UPDATE"],
                "enumDescriptions": ["仅插入时自动填充", "插入与更新时自动填充"],
                "description": "填充策略",
                "default": "INSERT",
                "markdownDescription": "INSERT：仅插入时填充；INSERT_UPDATE：插入与更新时填充"
              }
            }
          }
        },
        "mybatisToolkit.codeGen.mybatisPlus.logicDeleteField": {
          "type": "string",
          "default": "",
          "description": "MyBatis-Plus 逻辑删除字段（生成 Entity 时生效，下次生成会回显）",
          "markdownDescription": "选择 MyBatis-Plus 风格时，指定逻辑删除列名（如 `del_flag`），生成时添加 `@TableLogic`。"
        },
        "mybatisToolkit.codeGen.mybatisPlus.idType": {
          "type": "string",
          "default": "AUTO",
          "enum": ["AUTO", "ASSIGN_ID", "ASSIGN_UUID", "INPUT", "NONE"],
          "enumDescriptions": [
            "数据库自增（如 MySQL AUTO_INCREMENT）",
            "雪花算法分配 Long 或 UUID 字符串（推荐分布式）",
            "UUID 字符串",
            "用户手动输入",
            "无状态"
          ],
          "description": "MyBatis-Plus 主键生成策略（生成 Entity 时 @TableId 的 type）",
          "markdownDescription": "生成 MyBatis-Plus Entity 时主键字段的 `@TableId(type = IdType.xxx)`。**AUTO** 数据库自增；**ASSIGN_ID** 雪花 Long；**ASSIGN_UUID** UUID；**INPUT** 用户输入；**NONE** 无。"
        },
        "mybatisToolkit.codeGen.entityDirName": {
          "type": "string",
          "default": "entity",
          "description": "生成代码：Entity 目录名（包最后一段）",
          "markdownDescription": "Entity 类所在包的最后一段目录名，如 `entity`、`po`、`domain`。生成路径：`basePackage.entityDirName`。"
        },
        "mybatisToolkit.codeGen.mapperDirName": {
          "type": "string",
          "default": "mapper",
          "description": "生成代码：Mapper/DAO 目录名（包最后一段）",
          "markdownDescription": "Mapper 接口所在包的最后一段目录名，如 `mapper`、`dao`。生成路径：`basePackage.mapperDirName`。"
        },
        "mybatisToolkit.codeGen.xmlDirName": {
          "type": "string",
          "default": "mapper",
          "description": "生成代码：Mapper XML 目录名（resources 下）",
          "markdownDescription": "Mapper XML 文件在 `src/main/resources` 下的目录名，如 `mapper`、`mappers`、`xml`。"
        },
        "mybatisToolkit.codeGen.serviceDirName": {
          "type": "string",
          "default": "service",
          "description": "生成代码：Service 目录名（预留）",
          "markdownDescription": "Service 类所在包的最后一段目录名，如 `service`、`services`。预留供后续生成 Service 层使用。"
        },
        "mybatisToolkit.formatting.indentSize": {
          "type": "number",
          "default": 2,
          "description": "SQL 格式化缩进空格数",
          "markdownDescription": "格式化 XML 内 SQL 时每级缩进的空格数。",
          "minimum": 1,
          "maximum": 8
        },
        "mybatisToolkit.highlights.tableNameColor": {
          "type": "string",
          "format": "color-hex",
          "default": "#FFAB70",
          "description": "表名高亮颜色（如 FROM 后）",
          "markdownDescription": "SQL 中表名的语义高亮颜色。"
        },
        "mybatisToolkit.highlights.keywordColor": {
          "type": "string",
          "format": "color-hex",
          "default": "#C586C0",
          "description": "SQL 关键字颜色（SELECT、WHERE 等）",
          "markdownDescription": "SQL 关键字的语义高亮颜色。"
        },
        "mybatisToolkit.highlights.functionColor": {
          "type": "string",
          "format": "color-hex",
          "default": "#DCDCAA",
          "description": "SQL 函数颜色（COUNT、MAX 等）",
          "markdownDescription": "SQL 函数的语义高亮颜色。"
        },
        "mybatisToolkit.highlights.paramColor": {
          "type": "string",
          "format": "color-hex",
          "default": "#9CDCFE",
          "description": "MyBatis 参数颜色（#{...}、${...}）",
          "markdownDescription": "MyBatis 参数 `#{}`、`${}` 的语义高亮颜色。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@dbcode/vscode-api": "^1.1.1",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.18.0",
    "@types/vscode": "^1.90.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.0.0",
    "vscode": "npm:@types/vscode@^1.90.0",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "mysql2": "^3.15.3",
    "pg": "^8.13.0"
  },
  "optionalDependencies": {
    "oracledb": "^6.7.0"
  }
}
